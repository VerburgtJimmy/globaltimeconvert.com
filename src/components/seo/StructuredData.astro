---
// Renders one or more JSON-LD blocks. Used by Meta.astro.
interface Props {
  data: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { data } = Astro.props;
const items: Array<Record<string, unknown>> = Array.isArray(data) ? data : [data];

// Emit each schema as its own script tag — Google's docs recommend this over
// concatenating multiple schemas inside a single @graph wrapper, which is
// equally valid but harder to debug per-schema in Search Console.
---

{items.map((item) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
))}
