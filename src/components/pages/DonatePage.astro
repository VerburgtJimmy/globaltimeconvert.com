---
import Layout from '../Layout.astro';
import { t, pathFor, type Locale } from '../../lib/i18n';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---

<Layout
  title={t('templates.page.donate.title', lang)}
  description={t('templates.page.donate.description', lang)}
  lang={lang}
  breadcrumbs={[
    { name: t('ui.common.home', lang), url: pathFor('/', lang) },
    { name: t('ui.nav.donate', lang), url: pathFor('/donate', lang) },
  ]}
>
  <div class="mx-auto max-w-2xl px-6 pt-10">
    <nav class="text-[13px] text-neutral-500 dark:text-neutral-400" aria-label="Breadcrumb">
      <a href={pathFor('/', lang)} class="hover:text-neutral-900 dark:hover:text-neutral-100">
        {t('ui.common.home', lang)}
      </a>
      <span class="mx-2 text-neutral-300 dark:text-neutral-700">/</span>
      <span>{t('ui.nav.donate', lang)}</span>
    </nav>
  </div>

  <article class="mx-auto max-w-2xl px-6 pt-12 pb-24">
    <h1 class="text-[34px] leading-[1.1] font-semibold tracking-tight sm:text-[42px]">
      {t('templates.page.donate.h1', lang)}
    </h1>
    <div class="mt-8 space-y-5 text-[16.5px] leading-[1.75] text-neutral-700 dark:text-neutral-300">
      <p>{t('templates.page.donate.p1', lang)}</p>
      <p>{t('templates.page.donate.p2', lang)}</p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <a
        href="https://ko-fi.com/"
        rel="noopener external"
        class="group block rounded-2xl border border-hair p-6 transition-colors hover:border-accent-300"
      >
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[#FF5E5B] text-[15px] font-semibold text-white">
            k
          </div>
          <div>
            <div class="font-medium">{t('templates.page.donate.kofiTitle', lang)}</div>
            <div class="text-[12.5px] text-neutral-500 dark:text-neutral-400">
              {t('templates.page.donate.kofiSub', lang)}
            </div>
          </div>
          <svg
            class="ml-auto h-4 w-4 text-neutral-300 group-hover:text-accent-500"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M9 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
      </a>

      <a
        href="https://github.com/sponsors"
        rel="noopener external"
        class="group block rounded-2xl border border-hair p-6 transition-colors hover:border-accent-300"
      >
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
              <path d="M12 .5a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.74.08-.74 1.21.09 1.85 1.25 1.85 1.25 1.08 1.85 2.83 1.32 3.52 1.01.11-.78.42-1.32.77-1.62-2.66-.31-5.47-1.34-5.47-5.94 0-1.31.47-2.39 1.24-3.23-.13-.31-.54-1.55.12-3.23 0 0 1.01-.32 3.32 1.23a11.5 11.5 0 016.05 0c2.31-1.55 3.32-1.23 3.32-1.23.66 1.68.25 2.92.12 3.23.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0012 .5z" />
            </svg>
          </div>
          <div>
            <div class="font-medium">{t('templates.page.donate.githubTitle', lang)}</div>
            <div class="text-[12.5px] text-neutral-500 dark:text-neutral-400">
              {t('templates.page.donate.githubSub', lang)}
            </div>
          </div>
          <svg
            class="ml-auto h-4 w-4 text-neutral-300 group-hover:text-accent-500"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M9 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
      </a>
    </div>

    <div class="mt-12 border-t border-hair pt-8 text-[14px] leading-7 text-neutral-500 dark:text-neutral-400">
      <p>{t('templates.page.donate.thanks', lang)}</p>
    </div>
  </article>
</Layout>
