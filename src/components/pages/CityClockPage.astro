---
// Shared city-clock page body. Receives the already-resolved city from the
// page entrypoint — the entrypoint is responsible for the 404 case so the
// HTTP status propagates correctly (Response objects returned from inside
// /components/* don't halt the parent page's rendering in Astro).

import Layout from '../Layout.astro';
import YourTime from '../islands/YourTime.svelte';
import FaqList from '../FaqList.astro';
import { getDb, getCitiesAcrossZones, type CityWithCountry } from '../../lib/db';
import {
  formatInZone,
  formatOffset,
  observesDst,
  nextDstTransition,
  diffMin,
  describeDiff,
  formatHmsForLang,
} from '../../lib/tz';
import { t, pathFor, diffPhrase, type Locale } from '../../lib/i18n';
import { buildFAQPage, buildPlace, type FaqItem } from '../../lib/seo';

interface Props {
  lang: Locale;
  city: CityWithCountry;
}

const { lang, city } = Astro.props;

const now = new Date();
const time = formatInZone(now, city.timezone_id);
const offset = formatOffset(time.offsetMin);
const dst = observesDst(city.timezone_id);
const dstNext = dst ? nextDstTransition(city.timezone_id, now) : null;

// Locale-aware date string for the DST next-change line.
function dateLabelFor(at: Date, lang: Locale): string {
  const tag = lang === 'zh-CN' ? 'zh-CN' : lang;
  return new Intl.DateTimeFormat(tag, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: city.timezone_id,
  }).format(at);
}

const dstLine = (() => {
  if (!dst) return t('ui.common.notObserved', lang);
  const observed = t('ui.common.observed', lang);
  if (!dstNext) return observed;
  const next = t('ui.common.dstNextChange', lang, {
    date: dateLabelFor(dstNext.at, lang),
    dir: dstNext.forward ? '+' : '−',
  });
  return `${observed} · ${next}`;
})();

const db = getDb();
const others = await getCitiesAcrossZones(db, city.id, 12, lang);
const compareRows = others.map((other) => {
  const m = diffMin(city.timezone_id, other.timezone_id, now);
  const diff = describeDiff(m);
  return {
    other,
    diff,
    diffStr: diff.same ? t('ui.common.sameTime', lang) : diffPhrase(diff, lang),
  };
});

const title = t('templates.page.cityClock.title', lang, {
  city: city.display_name,
  country: city.country_name,
});
const description = t('templates.page.cityClock.metaDescription', lang, {
  city: city.display_name,
  country: city.country_name,
});

const populationFormatted = (() => {
  const p = city.population;
  if (p >= 1_000_000)
    return `${(p / 1_000_000).toFixed(2)} ${t('ui.common.millionsSuffix', lang)}`;
  if (p >= 1_000)
    return `${(p / 1_000).toFixed(0)} ${t('ui.common.thousandsSuffix', lang)}`;
  return p.toLocaleString('en-US');
})();

const breadcrumbs = [
  { name: t('ui.common.home', lang), url: pathFor('/', lang) },
  {
    name: t('ui.common.timeIn', lang, { city: city.display_name }),
    url: pathFor(`/time-in-${city.slug}`, lang),
  },
];

// FAQ — 3 questions per the SEO plan. Answers reference content on the
// page so they match what's actually rendered (Google requires that).
const faqVars = {
  city: city.display_name,
  tz: city.timezone_id,
  offset,
};
const faqs: FaqItem[] = [
  {
    question: t('templates.page.cityClock.faq.q1', lang, faqVars),
    answer: t(
      dst ? 'templates.page.cityClock.faq.a1Dst' : 'templates.page.cityClock.faq.a1NoDst',
      lang,
      faqVars,
    ),
  },
  {
    question: t('templates.page.cityClock.faq.q2', lang, faqVars),
    answer: t(
      dst ? 'templates.page.cityClock.faq.a2Yes' : 'templates.page.cityClock.faq.a2No',
      lang,
      faqVars,
    ),
  },
  {
    question: t('templates.page.cityClock.faq.q3', lang, faqVars),
    answer: t('templates.page.cityClock.faq.a3', lang, faqVars),
  },
];
const faqHeading = t('templates.page.cityClock.faq.heading', lang);

const extraStructuredData = [
  buildPlace({
    name: city.display_name,
    countryName: city.country_name,
    countryCode: city.country_code,
    latitude: city.latitude,
    longitude: city.longitude,
    timezoneId: city.timezone_id,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title={title}
  description={description}
  lang={lang}
  breadcrumbs={breadcrumbs}
  extraStructuredData={extraStructuredData}
>
  <!-- Breadcrumb -->
  <div class="mx-auto max-w-4xl px-6 pt-10">
    <nav class="text-[13px] text-neutral-500 dark:text-neutral-400" aria-label="Breadcrumb">
      <a href={pathFor('/', lang)} class="hover:text-neutral-900 dark:hover:text-neutral-100">
        {t('ui.common.home', lang)}
      </a>
      <span class="mx-2 text-neutral-300 dark:text-neutral-700">/</span>
      <span>{t('ui.common.timeIn', lang, { city: city.display_name })}</span>
    </nav>
  </div>

  <!-- Hero clock -->
  <section class="mx-auto max-w-4xl px-6 pt-10 pb-20 md:pb-24">
    <h1 class="text-[26px] font-semibold tracking-tight sm:text-3xl">
      {t('templates.page.cityClock.h1', lang, { city: city.display_name })}
    </h1>
    <div class="mt-10">
      <div
        class="display-time text-[64px] leading-none sm:text-7xl md:text-8xl"
        data-clock={city.timezone_id}
        data-format="HH:mm:ss"
      >
        {formatHmsForLang(time, lang)}
      </div>
      <div
        class="mt-5 text-[16px] text-neutral-600 sm:text-[17px] dark:text-neutral-400"
        data-clock={city.timezone_id}
        data-format="weekday-date"
      >
        {time.weekday}, {time.date}
      </div>
    </div>
  </section>

  <!-- Your time (filled in client-side; pages stay edge-cacheable) -->
  <section class="mx-auto max-w-4xl border-t border-hair px-6 py-12">
    <YourTime
      client:load
      lang={lang}
      momentIso={now.toISOString()}
      sourceLabel={`${t('ui.converter.now', lang)} in ${city.display_name}`}
    />
  </section>

  <!-- Metadata grid -->
  <section class="mx-auto max-w-4xl border-t border-hair px-6 py-12">
    <h2 class="eyebrow mb-6">{t('ui.common.timezoneDetails', lang)}</h2>
    <dl class="grid grid-cols-2 gap-x-8 gap-y-7 md:grid-cols-3">
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.ianaTimezone', lang)}</dt>
        <dd class="font-mono text-[14px]">{city.timezone_id}</dd>
      </div>
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.utcOffset', lang)}</dt>
        <dd class="font-mono text-[14px]">{offset}</dd>
      </div>
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.abbreviation', lang)}</dt>
        <dd class="font-mono text-[14px]">{time.abbr}</dd>
      </div>
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.daylightSaving', lang)}</dt>
        <dd class="text-[14px]">{dstLine}</dd>
      </div>
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.population', lang)}</dt>
        <dd class="tnum text-[14px]">{populationFormatted}</dd>
      </div>
      <div>
        <dt class="mb-1.5 text-[12px] text-neutral-500 dark:text-neutral-400">{t('ui.common.country', lang)}</dt>
        <dd class="text-[14px]">{city.country_name}</dd>
      </div>
    </dl>
  </section>

  <!-- Comparison rows -->
  <section class="mx-auto max-w-4xl border-t border-hair px-6 py-14">
    <h2 class="text-[20px] font-semibold tracking-tight sm:text-[22px]">
      {t('templates.page.cityClock.compareHeading', lang, { city: city.display_name })}
    </h2>
    <p class="mt-2 mb-8 text-[14px] text-neutral-500 dark:text-neutral-400">
      {t('ui.common.compareIntro', lang)}
    </p>
    <div class="border-t border-hair">
      {compareRows.map(({ other, diffStr }) => (
        <a
          href={pathFor(`/${city.slug}-to-${other.slug}`, lang)}
          class="grid grid-cols-[1fr_auto] items-baseline border-b border-hair px-1 py-5 transition-colors hover:bg-neutral-50 dark:hover:bg-neutral-900/60"
        >
          <div>
            <div class="font-medium">{other.display_name}</div>
            <div class="text-[12.5px] text-neutral-500 dark:text-neutral-400">{other.country_name}</div>
          </div>
          <div class="text-right">
            <div
              class="display-time text-[18px]"
              data-clock={other.timezone_id}
              data-format="HH:mm"
            >
              --:--
            </div>
            <div class="mt-0.5 text-[12px] text-neutral-500 dark:text-neutral-400">
              {diffStr}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <FaqList heading={faqHeading} items={faqs} />
</Layout>
