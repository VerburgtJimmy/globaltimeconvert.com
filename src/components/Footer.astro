---
import { t, pathFor, SUPPORTED_LOCALES, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;
const year = new Date().getUTCFullYear();

// Languages-region link list. Each non-current locale links to the homepage
// in that locale; current locale is shown as plain text.
const LOCALE_LABELS: Record<Locale, string> = {
  en: 'English',
  es: 'Español',
  pt: 'Português',
  de: 'Deutsch',
  nl: 'Nederlands',
  'zh-CN': '中文',
};
---

<footer class="mt-20 border-t border-hair">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-6 py-10 text-[13.5px] md:grid-cols-3">
    <div class="md:col-span-1">
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.5" />
          <path
            d="M12 7v5l3.2 2"
            stroke="var(--color-accent-500)"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span class="font-medium">{t('ui.site.name', lang)}</span>
      </div>
      <p class="mt-3 max-w-xs leading-6 text-neutral-500 dark:text-neutral-400">
        {t('ui.common.footerTaglineLong', lang)}
      </p>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:col-span-2">
      <div>
        <div class="eyebrow mb-3">{t('ui.common.supportRegion', lang)}</div>
        <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
          <li>
            <a href="https://ko-fi.com/jimmyverburgt" rel="noopener external" class="hover:text-neutral-900 dark:hover:text-neutral-100">
              Ko-fi
            </a>
          </li>
          <li>
            <a href="https://github.com/sponsors/VerburgtJimmy" rel="noopener external" class="hover:text-neutral-900 dark:hover:text-neutral-100">
              GitHub Sponsors
            </a>
          </li>
        </ul>
      </div>
      <div>
        <div class="eyebrow mb-3">{t('ui.common.siteRegion', lang)}</div>
        <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
          <li><a href={pathFor('/about', lang)} class="hover:text-neutral-900 dark:hover:text-neutral-100">{t('ui.nav.about', lang)}</a></li>
          <li><a href="/privacy" class="hover:text-neutral-900 dark:hover:text-neutral-100">{t('ui.nav.privacy', lang)}</a></li>
          <li><a href="/terms" class="hover:text-neutral-900 dark:hover:text-neutral-100">{t('ui.nav.terms', lang)}</a></li>
        </ul>
      </div>
      <div>
        <div class="eyebrow mb-3">{t('ui.common.languagesRegion', lang)}</div>
        <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
          {SUPPORTED_LOCALES.map((loc) => (
            <li>
              {loc === lang ? (
                <span class="text-neutral-900 dark:text-neutral-100">{LOCALE_LABELS[loc]}</span>
              ) : (
                <a href={pathFor('/', loc)} hreflang={loc} class="hover:text-neutral-900 dark:hover:text-neutral-100">
                  {LOCALE_LABELS[loc]}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-hair">
    <div class="mx-auto max-w-6xl px-6 py-5 text-[12px] text-neutral-400 dark:text-neutral-500">
      © {year} {t('ui.site.name', lang)}. {t('ui.common.noCookiesTrackersAds', lang)}
    </div>
  </div>
</footer>
