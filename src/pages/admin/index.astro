---
import Layout from '../../components/Layout.astro';
import {
  totalsToday,
  totalsLastDays,
  dailySeries,
  topPages,
  topSearches,
  topReferrers,
  topCountries,
  pickNumber,
} from '../../lib/ae';

export const prerender = false;

// Run all queries in parallel — each is KV-cached 5 min, so cost stays low.
const [today, sevenDays, series, pages, searches, refs, countries] = await Promise.all([
  totalsToday(),
  totalsLastDays(7),
  dailySeries(14),
  topPages(7, 20),
  topSearches(7, 20),
  topReferrers(7, 20),
  topCountries(7, 20),
]);

const todayPv = pickNumber(today, 'pageviews');
const todayVs = pickNumber(today, 'visitors');
const weekPv = pickNumber(sevenDays, 'pageviews');
const weekVs = pickNumber(sevenDays, 'visitors');

// Build a tiny SVG sparkline from the daily-series rows. SVG is design-system
// compliant: no chart library bundle, hairline stroke, single accent.
const seriesRows = series.rows as Array<{ day: string; pageviews: number; visitors: number }>;
const maxPv = seriesRows.length > 0 ? Math.max(...seriesRows.map((r) => r.pageviews)) : 1;
const sparkPoints = seriesRows
  .map((r, i) => {
    const x = seriesRows.length === 1 ? 50 : (i / (seriesRows.length - 1)) * 100;
    const y = maxPv === 0 ? 50 : 50 - (r.pageviews / maxPv) * 45;
    return `${x.toFixed(2)},${y.toFixed(2)}`;
  })
  .join(' ');

// True when the AE token isn't configured — show a friendly setup banner.
const unconfigured = today.cached === false && today.rows.length === 0 && todayPv === 0 && todayVs === 0;

const fmt = (n: number): string => n.toLocaleString('en-US');

function pathDisplay(p: string): string {
  if (!p) return '/';
  if (p.length > 60) return p.slice(0, 57) + '…';
  return p;
}
---

<Layout
  title="Admin · globaltimeconvert.com"
  description="Internal analytics dashboard."
  noindex
  localesAvailable={['en']}
>
  <div class="mx-auto max-w-6xl px-6 pt-10">
    <nav class="text-[13px] text-neutral-500 dark:text-neutral-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-neutral-900 dark:hover:text-neutral-100">Home</a>
      <span class="mx-2 text-neutral-300 dark:text-neutral-700">/</span>
      <span>Admin</span>
    </nav>
  </div>

  <section class="mx-auto max-w-6xl px-6 pt-10 pb-12">
    <div class="flex items-baseline justify-between">
      <h1 class="text-[26px] font-semibold tracking-tight sm:text-3xl">Analytics</h1>
      <span class="font-mono text-[12px] text-neutral-400">
        Last 7 days · UTC · cache 5m
      </span>
    </div>
    <p class="mt-4 text-[16px] leading-7 text-neutral-600 dark:text-neutral-400">
      Pageviews, visitors, top pages, searches, referrers, and countries. Read directly
      from Workers Analytics Engine — no cookies, no fingerprinting, IPs hashed daily.
    </p>
  </section>

  {unconfigured && (
    <section class="mx-auto max-w-6xl px-6 pb-8">
      <div class="rounded-2xl border border-hair px-6 py-5">
        <p class="eyebrow mb-2">Setup required</p>
        <p class="text-[14px] leading-6 text-neutral-700 dark:text-neutral-300">
          The dashboard isn't reading any data yet. Configure
          <code class="font-mono text-[13px]">CF_ACCOUNT_ID</code> and the
          <code class="font-mono text-[13px]">CF_API_TOKEN</code> secret — see PLAN §11
          for steps. Until then, this page renders with empty values.
        </p>
      </div>
    </section>
  )}

  <!-- Top tiles -->
  <section class="mx-auto max-w-6xl border-t border-hair px-6 py-12">
    <h2 class="eyebrow mb-6">Today</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-hair px-5 py-5">
        <p class="text-[12px] text-neutral-500 dark:text-neutral-400">Pageviews today</p>
        <p class="display-time mt-2 text-3xl">{fmt(todayPv)}</p>
      </div>
      <div class="rounded-xl border border-hair px-5 py-5">
        <p class="text-[12px] text-neutral-500 dark:text-neutral-400">Visitors today</p>
        <p class="display-time mt-2 text-3xl">{fmt(todayVs)}</p>
      </div>
      <div class="rounded-xl border border-hair px-5 py-5">
        <p class="text-[12px] text-neutral-500 dark:text-neutral-400">Pageviews · 7d</p>
        <p class="display-time mt-2 text-3xl">{fmt(weekPv)}</p>
      </div>
      <div class="rounded-xl border border-hair px-5 py-5">
        <p class="text-[12px] text-neutral-500 dark:text-neutral-400">Visitors · 7d</p>
        <p class="display-time mt-2 text-3xl">{fmt(weekVs)}</p>
      </div>
    </div>

    {seriesRows.length > 1 && (
      <div class="mt-8 rounded-xl border border-hair px-5 py-5">
        <p class="eyebrow mb-3">Pageviews · last 14 days</p>
        <svg viewBox="0 0 100 50" class="h-24 w-full" preserveAspectRatio="none">
          <polyline
            points={sparkPoints}
            fill="none"
            stroke="var(--color-accent-500)"
            stroke-width="0.8"
            vector-effect="non-scaling-stroke"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <div class="mt-2 flex justify-between font-mono text-[10px] text-neutral-400">
          <span>{seriesRows[0]?.day}</span>
          <span>{seriesRows[seriesRows.length - 1]?.day}</span>
        </div>
      </div>
    )}
  </section>

  <!-- Top pages -->
  <section class="mx-auto max-w-6xl border-t border-hair px-6 py-12">
    <h2 class="text-[20px] font-semibold tracking-tight sm:text-[22px]">Top pages</h2>
    <p class="mt-2 mb-6 text-[14px] text-neutral-500 dark:text-neutral-400">
      Last 7 days, by pageviews.
    </p>
    {pages.rows.length === 0 ? (
      <p class="text-[14px] text-neutral-500">No data yet.</p>
    ) : (
      <div class="border-t border-hair">
        <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[11px] tracking-[0.12em] text-neutral-400 uppercase">
          <div>Path</div>
          <div class="text-right">Pageviews</div>
          <div class="text-right">Visitors</div>
        </div>
        {pages.rows.map((r) => (
          <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[14px]">
            <div class="truncate font-mono text-[13px]">{pathDisplay(String(r.path))}</div>
            <div class="tnum text-right">{fmt(Number(r.pageviews))}</div>
            <div class="tnum text-right text-neutral-500">{fmt(Number(r.visitors))}</div>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Top searches -->
  <section class="mx-auto max-w-6xl border-t border-hair px-6 py-12">
    <h2 class="text-[20px] font-semibold tracking-tight sm:text-[22px]">Top searches</h2>
    <p class="mt-2 mb-6 text-[14px] text-neutral-500 dark:text-neutral-400">
      What people are typing into the city search.
    </p>
    {searches.rows.length === 0 ? (
      <p class="text-[14px] text-neutral-500">No data yet.</p>
    ) : (
      <div class="border-t border-hair">
        <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[11px] tracking-[0.12em] text-neutral-400 uppercase">
          <div>Query</div>
          <div class="text-right">Searches</div>
          <div class="text-right">Visitors</div>
        </div>
        {searches.rows.map((r) => (
          <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[14px]">
            <div class="truncate">{String(r.query)}</div>
            <div class="tnum text-right">{fmt(Number(r.searches))}</div>
            <div class="tnum text-right text-neutral-500">{fmt(Number(r.visitors))}</div>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Top referrers -->
  <section class="mx-auto max-w-6xl border-t border-hair px-6 py-12">
    <h2 class="text-[20px] font-semibold tracking-tight sm:text-[22px]">Top referrers</h2>
    <p class="mt-2 mb-6 text-[14px] text-neutral-500 dark:text-neutral-400">
      Hostnames only — full referrer URLs are never stored.
    </p>
    {refs.rows.length === 0 ? (
      <p class="text-[14px] text-neutral-500">No data yet.</p>
    ) : (
      <div class="border-t border-hair">
        <div class="grid grid-cols-[1fr_auto] gap-x-6 border-b border-hair px-1 py-3 text-[11px] tracking-[0.12em] text-neutral-400 uppercase">
          <div>Referrer</div>
          <div class="text-right">Pageviews</div>
        </div>
        {refs.rows.map((r) => (
          <div class="grid grid-cols-[1fr_auto] gap-x-6 border-b border-hair px-1 py-3 text-[14px]">
            <div class="truncate font-mono text-[13px]">{String(r.referrer)}</div>
            <div class="tnum text-right">{fmt(Number(r.pageviews))}</div>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Top countries -->
  <section class="mx-auto max-w-6xl border-t border-hair px-6 py-12">
    <h2 class="text-[20px] font-semibold tracking-tight sm:text-[22px]">Top countries</h2>
    <p class="mt-2 mb-6 text-[14px] text-neutral-500 dark:text-neutral-400">
      ISO-2 country codes from Cloudflare's edge geolocation. Country-level only.
    </p>
    {countries.rows.length === 0 ? (
      <p class="text-[14px] text-neutral-500">No data yet.</p>
    ) : (
      <div class="border-t border-hair">
        <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[11px] tracking-[0.12em] text-neutral-400 uppercase">
          <div>Country</div>
          <div class="text-right">Pageviews</div>
          <div class="text-right">Visitors</div>
        </div>
        {countries.rows.map((r) => (
          <div class="grid grid-cols-[1fr_auto_auto] gap-x-6 border-b border-hair px-1 py-3 text-[14px]">
            <div class="font-mono text-[13px]">{String(r.country) || '—'}</div>
            <div class="tnum text-right">{fmt(Number(r.pageviews))}</div>
            <div class="tnum text-right text-neutral-500">{fmt(Number(r.visitors))}</div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
